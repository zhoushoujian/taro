{
  "eslint.enable": true,
  "editor.formatOnSave": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.tabSize": 2,
  "stylelint.validate": [
    "css",
    "less"
  ],
  "css.validate": true,
  "less.validate": true,
  "[less]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.stylelint": "explicit"
    }
  },
  "git.ignoreLimitWarning": true
}
